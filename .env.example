BASE_URL=https://pos.palletnow.co
POS_USERNAME=your_mobile_number
POS_PIN=your_pin

# ── Slack integration ──────────────────────────────────────────────────────────
# Bot token from your Slack App (OAuth & Permissions → Bot User OAuth Token)
# Required scopes: chat:write, commands
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App signing secret (Basic Information → App Credentials)
SLACK_SIGNING_SECRET=your_signing_secret_here

# Channel to post results to (defaults to #qa-automation if not set)
SLACK_CHANNEL=#qa-automation

# ── GitHub Actions ─────────────────────────────────────────────────────────────
# Fine-grained PAT with Contents: write on this repo (for repository_dispatch)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_pat_here

GITHUB_REPO_OWNER=your_github_org_or_username
GITHUB_REPO_NAME=pallet-pos-tests

# Shared secret for the /slack/results webhook (generate with: openssl rand -hex 32)
RESULTS_WEBHOOK_SECRET=your_results_webhook_secret_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
